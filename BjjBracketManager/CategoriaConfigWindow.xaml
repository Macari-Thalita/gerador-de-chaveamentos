<Window x:Class="BjjBracketManager.CategoriaConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Revisar dados importados" Height="620" Width="1050"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <Grid DockPanel.Dock="Bottom" Margin="0 10 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Content="Ajustar duplicatas"
                    Width="140"
                    Height="32"
                    Click="AjustarDuplicatas_Click" />

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="Cancelar" Width="100" Height="32" Click="Cancelar_Click" />
                <Button Content="Aplicar" Width="100" Height="32" Margin="8 0 0 0" Click="Aplicar_Click" />
            </StackPanel>
        </Grid>

        <DataGrid x:Name="GridRevisao"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="True">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding PossivelDuplicado}" Value="True">
                            <Setter Property="Background" Value="#FFFFF3CD" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="2*" />
                <DataGridTextColumn Header="Gênero" Binding="{Binding Genero}" Width="*" />
                <DataGridTextColumn Header="Peso" Binding="{Binding Peso}" Width="*" />
                <DataGridTextColumn Header="Graduação" Binding="{Binding Graduacao}" Width="*" />
                <DataGridTextColumn Header="Idade" Binding="{Binding CategoriaIdade}" Width="*" />
                <DataGridTextColumn Header="Equipe" Binding="{Binding Equipe}" Width="2*" />
                <DataGridTextColumn Header="Observação" Binding="{Binding Observacoes}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
