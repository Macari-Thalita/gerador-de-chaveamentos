<Window x:Class="BjjBracketManager.ExportarChaveamentoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exportar chaveamento" Height="210" Width="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 16 0 0">
            <Button Content="Cancelar" Width="96" Height="32" Click="Cancelar_Click" />
            <Button Content="Continuar" Width="96" Height="32" Margin="8 0 0 0" Click="Continuar_Click" />
        </StackPanel>

        <StackPanel>
            <TextBlock Text="Escolha o PDF que deseja gerar:" FontWeight="SemiBold" Margin="0 0 0 12" />
            <RadioButton x:Name="OpcaoChaveAtual" Content="Chave atual" IsChecked="True" Margin="0 0 0 8" />
            <RadioButton x:Name="OpcaoTodasChaves" Content="Todas as chaves" />
        </StackPanel>
    </DockPanel>
</Window>
